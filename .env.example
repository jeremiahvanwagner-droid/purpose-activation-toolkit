# ---------------------------------------------------------------------------
# Supabase — REQUIRED in production.
#
# These are inlined into the client bundle at BUILD time, so setting them in
# Vercel is not enough on its own: you must redeploy afterwards or the build
# ships with empty strings. When they are missing, lib/supabase.ts returns null,
# lib/entitlements.ts fails closed to "signed-out", and every paying customer is
# locked out of the modules they bought. (This is exactly what happened on
# 2026-07-22 — the previous version of this file said "leave blank for now".)
#
# Umbrella project: aagqvfwuixpxtdcrdxmv
# ---------------------------------------------------------------------------
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=

# Public download URL for the free eBook gifted on audit completion.
# Hosted in the public `project-assets` bucket on the Umbrella project.
# Client-visible on purpose — the book is a free gift, not gated content.
NEXT_PUBLIC_EBOOK_URL=

# ---------------------------------------------------------------------------
# SERVER-ONLY — used by app/api/audit-complete/route.ts.
# Never prefix these with NEXT_PUBLIC_; that would ship them to the browser.
# ---------------------------------------------------------------------------

# Bypasses RLS to write public.audit_leads. Umbrella project.
SUPABASE_SERVICE_ROLE_KEY=

# GoHighLevel — Truth J Blue location. The upsert here tags the lead
# `audit-completed`, which is what fires the delivery workflow that emails the
# book. Sending stays on TJB's warm GHL sender, so no new SPF/DKIM is needed.
GHL_LOCATION_ID_TJB=
GHL_PRIVATE_INTEGRATION_TOKEN_TJB=
